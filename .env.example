# ── SMTP Configuration (Contact Form) ──
# Use Gmail App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
CONTACT_EMAIL=your-email@gmail.com

# ── WhatsApp Click-to-Chat ──
# Country code + number WITHOUT any prefix or +
NEXT_PUBLIC_WHATSAPP_NUMBER="910122224244"

# ── AI Chatbot (optional) ──
# Leave empty to use FAQ mode; set your key for GPT responses
OPENAI_API_KEY=
